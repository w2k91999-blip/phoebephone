# ── Vapi ────────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.vapi.ai  ->  "API Keys"  ->  use your PRIVATE key
VAPI_API_KEY=

# ── Cal.com (free booking backend) ───────────────────────────────────────────
# https://app.cal.com/settings/developer/api-keys
# This is the default key; a client config file can override it per client.
CALCOM_API_KEY=

# ── Booking server ───────────────────────────────────────────────────────────
# Public URL where THIS server is reachable by Vapi's cloud.
# Local dev: run `ngrok http 3000` and paste the https URL it gives you.
# Production: your Render/Railway/Vercel URL.
SERVER_URL=
PORT=3000

# Optional shared secret — set the same value in Vapi's server settings so the
# booking server can reject calls that aren't from your Vapi account.
VAPI_WEBHOOK_SECRET=

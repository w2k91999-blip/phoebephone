# ── Vapi ────────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.vapi.ai  ->  "API Keys"  ->  use your PRIVATE key
VAPI_API_KEY=

# ── Cal.com (free booking backend) ───────────────────────────────────────────
# https://app.cal.com/settings/developer/api-keys
# This is the default key; a client config file can override it per client.
CALCOM_API_KEY=

# ── Booking server ───────────────────────────────────────────────────────────
# Public URL where THIS server is reachable by Vapi's cloud.
# Local dev: run `ngrok http 3000` and paste the https URL it gives you.
# Production: your Render/Railway/Vercel URL.
SERVER_URL=
PORT=3000

# Optional shared secret — set the same value in Vapi's server settings so the
# booking server can reject calls that aren't from your Vapi account.
VAPI_WEBHOOK_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys  (use the SECRET key)
STRIPE_SECRET_KEY=sk_live_…

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_…

# Price IDs for each plan — Stripe Dashboard → Products → your plan → copy Price ID
STRIPE_PRICE_BASIC=price_…
STRIPE_PRICE_PROFESSIONAL=price_…
STRIPE_PRICE_PREMIUM=price_…

# ── Supabase (server-side) ────────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://lrxuflxfnyiqzjqzjcsa.supabase.co
# Use the SERVICE ROLE key (not the anon key) — keep this secret, server only
SUPABASE_SERVICE_ROLE_KEY=eyJ…
